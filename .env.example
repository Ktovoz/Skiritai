# Server
LOG_LEVEL=INFO
HEADLESS=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Optional: Anthropic
# ANTHROPIC_API_KEY=your-anthropic-key
