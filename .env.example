# ============================================================
# Skiritai 配置
# 环境变量支持 SKIRITAI_ 前缀（推荐），旧名称仍向后兼容
# ============================================================

# --- 框架配置 ---
SKIRITAI_LOG_LEVEL=INFO              # 旧名: LOG_LEVEL
SKIRITAI_HEADLESS=false              # 旧名: HEADLESS
# SKIRITAI_CHROME_PATH=              # 自定义 Chrome 路径（旧名: CHROME_PATH）
# SKIRITAI_LOG_DIR=.skiritai/logs    # 日志目录
# SKIRITAI_CASES_ROOT=cases          # Web 模式下用例根目录
# SKIRITAI_CORS_ORIGINS=http://localhost:5173  # Web 模式 CORS（旧名: CORS_ALLOWED_ORIGINS）

# ============================================================
# LLM Provider 配置
# 支持: openai, anthropic
# 按需取消注释一个配置段，修改 API key 即可使用
# ============================================================

# --- GPTSAPI (gpt-5) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-gptsapi-key-here
# OPENAI_BASE_URL=https://api.gptsapi.net/v1
# LLM_MODEL=gpt-5

# --- OpenAI 官方 ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# --- SiliconFlow (Qwen3 等) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-siliconflow-key-here
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# LLM_MODEL=Qwen/Qwen3-VL-32B-Thinking

# --- Anthropic (需安装: pip install skiritai[anthropic]) ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-key
# LLM_MODEL=claude-sonnet-4-20250514
