# Server 配置
LOG_LEVEL=INFO
HEADLESS=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ============================================================
# LLM Provider 配置
# 支持: openai, anthropic
# 按需取消注释一个配置段，修改 API key 即可使用
# ============================================================

# --- GPTSAPI (gpt-5) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-gptsapi-key-here
# OPENAI_BASE_URL=https://api.gptsapi.net/v1
# LLM_MODEL=gpt-5

# --- OpenAI 官方 ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# --- SiliconFlow (Qwen3 等) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-siliconflow-key-here
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# LLM_MODEL=Qwen/Qwen3-VL-32B-Thinking

# --- Anthropic (可选，需安装 langchain-anthropic) ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-key
# LLM_MODEL=claude-sonnet-4-20250514
